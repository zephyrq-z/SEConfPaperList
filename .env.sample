# SEConfPaperList 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ----- 数据补充（ENRICH=1 时启用）-----

# 补充数据来源（默认 researchr）
#   researchr - 原生爬取 conf.researchr.org 详情页，100% 覆盖，无需 API key
#   external  - 使用 DBLP + arXiv + Semantic Scholar 外部 API
ENRICH_SOURCE=researchr

# Semantic Scholar API Key（仅 ENRICH_SOURCE=external 时需要）
# 免费申请: https://api.semanticscholar.org/
SEMANTIC_SCHOLAR_API_KEY=

# ----- 中文翻译（ENRICH_TRANSLATE=1 时启用）-----

# OpenAI 兼容 API（必填）
OPENAI_API_KEY=

# API 地址（可选，默认 https://api.openai.com/v1）
OPENAI_BASE_URL=https://api.openai.com/v1

# 翻译模型（可选，默认 gpt-4o-mini）
TRANSLATE_MODEL=gpt-4o-mini

# ----- 运行模式 -----

# 是否启用数据补充（默认 1）
ENRICH=1

# 是否启用中文翻译（默认 0，需要配置 OPENAI_API_KEY）
ENRICH_TRANSLATE=0