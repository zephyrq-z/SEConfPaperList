#!/usr/bin/env python3
"""Scrape papers from SE conferences and enrich with researchr metadata.

Usage:
    python scrape_papers.py                           # scrape all conferences
    python scrape_papers.py --conf "ICSE 2026"        # scrape single conference
    python scrape_papers.py --output data/run2.jsonl  # custom output file
"""

import argparse
import logging
import os
import sys
import time

import orjson
import requests
from lxml import html as lxml_html

from lib.config import CONFERENCES
from lib.io import save_jsonl, load_existing, merge_items
from lib.researchr import extract_form_params, fetch_detail_url, fetch_abstract, fetch_preprint_links

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
logger = logging.getLogger(__name__)

DEFAULT_OUTPUT = os.path.join(os.path.dirname(os.path.abspath(__file__)), "data", "papers.jsonl")
HEADERS = {"User-Agent": "Mozilla/5.0"}


def scrape_listing(conf_info: dict, limit: int = 0) -> list[dict]:
    """Scrape paper titles, authors, and UUIDs from a conference listing page."""
    url = conf_info["url"]
    conf_name = conf_info["conf"]
    track_label = conf_info.get("track", "Research Track")
    logger.info("Fetching listing: %s", url)
    resp = requests.get(url, headers=HEADERS, timeout=30)
    resp.raise_for_status()
    tree = lxml_html.fromstring(resp.content)

    items = []
    rows = tree.cssselect("tr")
    for row in rows:
        # Find paper link: <a href="#" data-event-modal="UUID">TITLE</a>
        title_el = row.cssselect("a[data-event-modal]")
        if not title_el:
            continue
        # Check track label matches
        track_el = row.cssselect("div.prog-track")
        if not track_el or track_el[0].text_content().strip() != track_label:
            continue
        if limit > 0 and len(items) >= limit:
            break
        title = title_el[0].text_content().strip()
        uuid = title_el[0].get("data-event-modal", "")

        # Extract authors from performers div
        authors = ""
        performers_el = row.cssselect("div.performers")
        if performers_el:
            # Authors are in <a> tags inside performers div
            author_links = performers_el[0].cssselect("a")
            authors = ", ".join(a.text_content().strip() for a in author_links)

        items.append({
            "conf": conf_name,
            "title": title,
            "author": authors,
            "uuid": uuid,
            "abstract": "",
            "full_version_url": "",
            "arxiv_url": "",
            "arxiv_pdf_url": "",
            "title_cn": "",
            "abstract_cn": "",
        })
    return items


def enrich_papers(items: list[dict]) -> None:
    """Enrich papers with abstracts and arXiv links from researchr detail pages."""
    session = requests.Session()
    # Cache form params per conference URL (each page has unique hashes)
    form_params_cache: dict[str, dict] = {}

    def get_form_params(conf_url: str):
        if conf_url not in form_params_cache:
            try:
                resp = session.get(conf_url, headers=HEADERS, timeout=30)
                form_params_cache[conf_url] = extract_form_params(resp.text)
            except Exception:
                form_params_cache[conf_url] = None
        return form_params_cache[conf_url]

    total = len(items)
    detail_count = abstract_count = preprint_count = 0
    for i, item in enumerate(items):
        if i % 50 == 0 and i > 0:
            logger.info("Enrich: %d/%d (detail=%d, abstract=%d, preprint=%d)",
                        i, total, detail_count, abstract_count, preprint_count)
        uuid = item.get("uuid", "")
        if not uuid:
            continue

        # Find the conf URL for this item
        conf_url = ""
        for c in CONFERENCES:
            if c["conf"] == item["conf"]:
                conf_url = c["url"]
                break

        detail_url = fetch_detail_url(uuid, get_form_params(conf_url), session, conf_url)
        if detail_url:
            detail_count += 1
            item["full_version_url"] = detail_url

            abstract = fetch_abstract(detail_url, session)
            if abstract:
                abstract_count += 1
                item["abstract"] = abstract

            links = fetch_preprint_links(detail_url, session)
            for link in links:
                if "arxiv.org/abs/" in link:
                    item["arxiv_url"] = link
                    item["arxiv_pdf_url"] = link.replace("/abs/", "/pdf/") + ".pdf"
                    preprint_count += 1
                    break
        time.sleep(0.1)

    logger.info("Enrich done: %d/%d (detail=%d, abstract=%d, preprint=%d)",
                total, total, detail_count, abstract_count, preprint_count)


def _extract_year(item: dict) -> int:
    for token in reversed(item["conf"].split()):
        try:
            return int(token)
        except ValueError:
            continue
    return 0


def deduplicate_and_sort(items: list[dict]) -> list[dict]:
    seen: set[tuple[str, int]] = set()
    unique: list[dict] = []
    for item in items:
        key = (item["title"], _extract_year(item))
        if key not in seen:
            seen.add(key)
            unique.append(item)

    unique.sort(key=lambda x: (-_extract_year(x), x["conf"], x["title"]))
    return unique


def main() -> None:
    parser = argparse.ArgumentParser(description="Scrape SE conference papers")
    parser.add_argument("--conf", help="Scrape a single conference (e.g. 'ICSE 2026')")
    parser.add_argument("--exclude", help="Comma-separated conference names to skip")
    parser.add_argument("--output", default=DEFAULT_OUTPUT,
                        help=f"Output JSONL file (default: {DEFAULT_OUTPUT})")
    parser.add_argument("--limit", type=int, default=0,
                        help="Scrape at most N papers per conference (0 = unlimited)")
    args = parser.parse_args()

    output_path = args.output
    start = time.time()

    targets = CONFERENCES
    if args.conf:
        q = args.conf.lower().replace(" ", "")
        targets = [p for p in CONFERENCES if q in p["conf"].lower().replace(" ", "")]
        if not targets:
            logger.error("Conference '%s' not found in CONFERENCES", args.conf)
            sys.exit(1)

    if args.exclude:
        skip = {s.strip().lower().replace(" ", "") for s in args.exclude.split(",")}
        targets = [t for t in targets if t["conf"].lower().replace(" ", "") not in skip]
        logger.info("Excluded %d conference(s)", len(CONFERENCES) - len(targets))

    # Load existing papers once
    existing = load_existing(output_path)
    logger.info("Existing papers: %d", len(existing))

    for conf_info in targets:
        logger.info("Scraping %s...", conf_info["conf"])
        items = scrape_listing(conf_info, args.limit)
        logger.info("  %s: %d papers", conf_info["conf"], len(items))
        if not items:
            continue

        logger.info("  Enriching...")
        enrich_papers(items)
        abstract_ok = sum(1 for i in items if i.get("abstract"))
        arxiv_ok = sum(1 for i in items if i.get("arxiv_url"))
        logger.info("  %s: abstract=%d, arxiv=%d", conf_info["conf"], abstract_ok, arxiv_ok)

        # Merge into existing and save immediately
        all_items = merge_items(existing, items)
        all_items = deduplicate_and_sort(all_items)
        save_jsonl(all_items, output_path)
        # Reload existing for next conference
        existing = load_existing(output_path)
        logger.info("  %s: saved, total=%d", conf_info["conf"], len(existing))

    elapsed = time.time() - start
    logger.info("Done in %.1f minutes", elapsed / 60)


if __name__ == "__main__":
    main()